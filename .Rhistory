library(ggplot2)
ggplot(utilities, aes(
x = year,
y = therms_per_day,
group = building)) +
geom_path()
inutile <- utilities %>% mutate(my = year*12 + month)
ggplot(inutile, aes(
x = my,
y = therms_per_day,
group = building)) +
geom_path()
ggplot(inutile, aes(
x = my,
y = therms_per_day,
color = building)) +
geom_path()
