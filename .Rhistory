if(input$rank == 'By total emissions'){
# rank them by emissions
air %>% head
countries <- air %>%
group_by(entity) %>%
summarize(total = sum(total)) %>%
arrange(desc(total)) %>%
pull(entity)
}
# then build up your selectInput
selectInput(inputId = 'entity',
label = 'Select countries',
multiple = TRUE,
choices = countries,
selected = 'United Kingdom')
})
output$airplot <- renderPlot({
print(input$entity)
if(input$entity %>% is.null){
# this is where ALL countries are shown
ggplot(rv$air,
aes_string(x='year', y=input$yvar, group = 'entity')) +
geom_path() +
xlim(input$year)
}else{
# this is where only selected are shown
ggplot(rv$air,
aes_string(x='year', y=input$yvar, color='entity')) + # what we should actually do
geom_path() +
xlim(input$year)
}
})
output$dt1 <- renderDT({ rv$air })
}
# Run the application
shinyApp(ui = ui, server = server)
